{
  "name": "vanguard",
  "private": true,
  "description": "",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "react-router build",
    "db:migrate": "pnpm db:migrate:dev && pnpm db:migrate:test",
    "db:migrate:dev": "pnpm exec drizzle-kit migrate",
    "db:migrate:test": "dotenv -e .env.test -- pnpm exec drizzle-kit migrate",
    "db:seed": "tsx --env-file=.env ./drizzle/seed.ts",
    "dev": "NODE_OPTIONS='--import ./instrument.server.mjs' react-router dev",
    "docker": "docker-compose up -d",
    "preinstall": "npx only-allow pnpm",
    "prepare": "vp config",
    "start": "NODE_OPTIONS='--import ./instrument.server.mjs' react-router-serve ./build/server/index.js",
    "test": "pnpm db:migrate:test && pnpm test:vitest",
    "test:vitest": "dotenv -e .env.test -- vitest run",
    "test:watch": "dotenv -e .env.test -- vitest",
    "typecheck": "react-router typegen && tsc -b",
    "user": "tsx --env-file=.env ./bin/user.ts",
    "category": "tsx --env-file=.env ./bin/category.ts",
    "validate": "vp check && pnpm typecheck && pnpm test"
  },
  "dependencies": {
    "@fontsource/inter": "5.0.17",
    "@neondatabase/serverless": "1.1.0",
    "@paralleldrive/cuid2": "2.2.2",
    "@radix-ui/colors": "0.1.9",
    "@radix-ui/react-icons": "1.3.0",
    "@radix-ui/react-tabs": "1.0.4",
    "@radix-ui/react-toolbar": "1.0.4",
    "@react-router/fs-routes": "7.14.2",
    "@react-router/node": "7.14.2",
    "@react-router/serve": "7.14.2",
    "@sentry/react-router": "10.50.0",
    "@vercel/blob": "2.3.3",
    "@vercel/functions": "3.4.4",
    "@vercel/react-router": "1.2.6",
    "commander": "12.0.0",
    "dayjs": "1.11.10",
    "drizzle-orm": "0.45.2",
    "emoji-picker-react": "4.18.0",
    "isbot": "5.1.39",
    "isomorphic-dompurify": "2.6.0",
    "marked": "4.3.0",
    "nodemailer": "7.0.11",
    "pg": "8.20.0",
    "prismjs": "1.30.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-hot-toast": "2.4.1",
    "react-router": "7.15.1",
    "react-textarea-autosize": "8.5.3",
    "remix-auth": "3.6.0",
    "remix-auth-oauth2": "1.11.2",
    "sharp": "0.34.5",
    "tiny-invariant": "1.3.3"
  },
  "devDependencies": {
    "@faker-js/faker": "6.3.1",
    "@react-router/dev": "7.14.2",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.2.4",
    "@types/marked": "5.0.2",
    "@types/node": "24.12.2",
    "@types/nodemailer": "6.4.14",
    "@types/pg": "8.20.0",
    "@types/prismjs": "1.26.3",
    "@types/react": "18.2.70",
    "@types/react-dom": "18.2.22",
    "@vitejs/plugin-react": "6.0.1",
    "dotenv-cli": "6.0.0",
    "drizzle-kit": "0.31.10",
    "tailwindcss": "4.2.4",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vite": "8.0.10",
    "vite-plus": "0.1.24",
    "vitest": "4.1.5"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.4.1",
  "pnpm": {
    "overrides": {
      "form-data": "4.0.4",
      "axios": "1.15.0",
      "rollup": "4.60.2",
      "qs": "6.15.2",
      "ws": "8.20.1",
      "uuid": "11.1.1",
      "brace-expansion@5": "5.0.6"
    }
  }
}
