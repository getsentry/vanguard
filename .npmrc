legacy-peer-deps=true

# `sharp` ships native binaries via optionalDependencies. Without these hints
# pnpm installing on macOS skips the linux-x64 binary, and the Vercel runtime
# blows up at request time with `Could not load the "sharp" module`.
supported-architectures.os[]=darwin
supported-architectures.os[]=linux
supported-architectures.cpu[]=x64
supported-architectures.cpu[]=arm64
