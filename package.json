{
  "name": "vanguard",
  "private": true,
  "description": "",
  "license": "Apache-2.0",
  "sideEffects": false,
  "scripts": {
    "build": "react-router build",
    "db:migrate": "pnpm db:migrate:dev && pnpm db:migrate:test",
    "db:migrate:dev": "pnpm exec drizzle-kit migrate",
    "db:migrate:test": "dotenv -e .env.test -- pnpm exec drizzle-kit migrate",
    "db:seed": "ts-node -r esbuild-register -r dotenv/config ./drizzle/seed.ts",
    "dev": "react-router dev",
    "docker": "docker-compose up -d",
    "preinstall": "npx only-allow pnpm",
    "start": "react-router-serve ./build/server/index.js",
    "test": "pnpm db:migrate:test && pnpm test:vitest",
    "test:vitest": "dotenv -e .env.test -- vitest run --no-threads",
    "test:watch": "dotenv -e .env.test -- vitest --no-threads",
    "test:ci": "pnpm db:migrate:test && pnpm test:ci:vitest",
    "test:ci:vitest": "dotenv -e .env.test -- vitest run --no-threads --coverage --reporter=junit --outputFile=junit.xml --reporter=default",
    "typecheck": "react-router typegen && tsc -b",
    "user": "ts-node -r esbuild-register -r dotenv/config ./bin/user.ts",
    "category": "ts-node -r esbuild-register -r dotenv/config ./bin/category.ts",
    "validate": "vp check && pnpm typecheck && pnpm test"
  },
  "dependencies": {
    "@faker-js/faker": "^6.3.1",
    "@fontsource/inter": "^5.0.17",
    "@neondatabase/serverless": "^1.1.0",
    "@paralleldrive/cuid2": "^2.2.2",
    "@radix-ui/colors": "^0.1.9",
    "@radix-ui/react-icons": "^1.3.0",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toolbar": "^1.0.4",
    "@react-router/dev": "^7.14.2",
    "@react-router/fs-routes": "^7.14.2",
    "@react-router/node": "^7.14.2",
    "@react-router/serve": "^7.14.2",
    "@sentry/browser": "^10.50.0",
    "@sentry/react-router": "^10.50.0",
    "@sentry/vite-plugin": "^5.2.0",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "@testing-library/dom": "^9.3.4",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^14.2.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/bcrypt": "^5.0.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/marked": "^5.0.2",
    "@types/node": "^24.0.0",
    "@types/nodemailer": "^6.4.14",
    "@types/prismjs": "^1.26.3",
    "@types/react": "^18.2.70",
    "@types/react-dom": "^18.2.22",
    "@vercel/blob": "^2.3.3",
    "@vercel/functions": "^3.4.4",
    "@vercel/react-router": "^1.2.6",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^0.34.6",
    "autoprefixer": "^10.4.19",
    "bcrypt": "^5.1.1",
    "commander": "^12.0.0",
    "cross-env": "^7.0.3",
    "dayjs": "^1.11.10",
    "dotenv": "^16.4.5",
    "dotenv-cli": "^6.0.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "emoji-picker-react": "^3.6.5",
    "esbuild": "^0.20.2",
    "esbuild-register": "^3.5.0",
    "happy-dom": "^20.8.9",
    "isbot": "^5.1.39",
    "isomorphic-dompurify": "^2.6.0",
    "jsonwebtoken": "^9.0.2",
    "marked": "^4.3.0",
    "nodemailer": "^7.0.7",
    "pg": "^8.20.0",
    "postcss": "^8.4.38",
    "prism-sentry": "^1.0.2",
    "prismjs": "^1.29.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "react-router": "^7.14.2",
    "react-textarea-autosize": "^8.5.3",
    "remix-auth": "^3.6.0",
    "remix-auth-form": "^1.4.0",
    "remix-auth-oauth2": "^1.11.2",
    "slugify": "^1.6.6",
    "start-server-and-test": "^2.0.3",
    "tailwindcss": "^3.4.1",
    "tiny-invariant": "^1.3.3",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.3",
    "vite": "^5.4.21",
    "vite-tsconfig-paths": "^4.3.2",
    "vitest": "^0.33.0"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.4.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt"
    ],
    "overrides": {
      "form-data": "4.0.4"
    }
  }
}
