# ── Core ──────────────────────────────────────────────────────────────────────
BASE_URL=http://localhost:5173

# ── Database ──────────────────────────────────────────────────────────────────
# Neon connection string (recommended for production/preview deployments)
# DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
# Local Postgres via docker-compose:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SESSION_SECRET=super-duper-s3cret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Restrict login to a specific Google Workspace domain
GOOGLE_HD=sentry.io

# ── Storage (Vercel Blob) ──────────────────────────────────────────────────────
# Run `vercel env pull` after linking the project, or copy from the Vercel dashboard.
# Leave empty to use local filesystem (files served via /image-uploads/...)
BLOB_READ_WRITE_TOKEN=

# ── Email (SMTP) ───────────────────────────────────────────────────────────────
SMTP_FROM=vanguard@example.com
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# ── Slack ─────────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
SLACK_USERNAME=Vanguard
SLACK_ICON_URL=
# Override default channel
SLACK_CHANNEL=

# ── Sentry ────────────────────────────────────────────────────────────────────
# Server-side DSN (used by instrument.server.mjs and entry.server.tsx).
SENTRY_DSN=
# Client-side DSN — same value, but VITE_-prefixed so it's exposed to the
# browser bundle. The DSN is public; this is intentional.
VITE_SENTRY_DSN=
# Used by `sentryReactRouter` for source map upload during builds.
# Use an Organization Auth Token — https://sentry.io/orgredirect/organizations/:slug/settings/auth-tokens/
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
# Optional release identifier when VERCEL_GIT_COMMIT_SHA isn't available.
# The Sentry Vite plugin auto-detects releases on Vercel.
# VERSION=
# VITE_VERSION=  # client-side equivalent (shown in the footer + Sentry release tag)
